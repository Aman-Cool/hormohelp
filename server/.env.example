# PostgreSQL connection string (shared with auth-service)
DATABASE_URL=postgresql://harmohelp:harmohelp@localhost:5432/harmohelp

# Server
PORT=4000
NODE_ENV=development

# Frontend origin for CORS — no trailing slash
FRONTEND_ORIGIN=http://localhost:5173

# ── Auth service ──────────────────────────────────────────────────────────────
# URL of the Go auth-service. All /auth/* requests are proxied here.
AUTH_SERVICE_URL=http://localhost:8001

# Path to the RSA public key generated by the Go auth-service.
# Used to verify RS256 JWTs on protected CRUD routes.
# Generate with:
#   openssl genrsa -out auth_private.pem 2048
#   openssl rsa -in auth_private.pem -pubout -out auth_public.pem
#   cp auth_public.pem server/auth_public.pem
AUTH_PUBLIC_KEY_PATH=./auth_public.pem

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get test keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
