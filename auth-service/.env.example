# ── Server ────────────────────────────────────────────────────────────────────
PORT=8001
NODE_ENV=development          # set to "production" to enable Secure cookies + stricter behaviour

# ── Database ──────────────────────────────────────────────────────────────────
# Shared PostgreSQL instance with the Node.js API.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://harmohelp:harmohelp@localhost:5432/harmohelp

# ── RSA Key Pair (RS256 JWT signing) ─────────────────────────────────────────
# Generate once with:
#   openssl genrsa -out auth_private.pem 2048
#   openssl rsa -in auth_private.pem -pubout -out auth_public.pem
#
# Copy auth_public.pem to the Node.js server directory so it can verify tokens.
JWT_PRIVATE_KEY_PATH=./auth_private.pem
JWT_PUBLIC_KEY_PATH=./auth_public.pem

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used to construct email verification and password-reset links.
# No trailing slash.
FRONTEND_ORIGIN=http://localhost:5173

# ── SMTP ──────────────────────────────────────────────────────────────────────
# For local development use Ethereal (https://ethereal.email) — free fake SMTP.
# After signup, view sent messages at https://ethereal.email/messages.
#
# For production use a real provider: Resend, SendGrid, Mailgun, AWS SES, etc.
#
# SMTP_SECURE=false  → STARTTLS (port 587, most providers)
# SMTP_SECURE=true   → Implicit TLS (port 465)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-ethereal-user@ethereal.email
SMTP_PASS=your-ethereal-password
SMTP_FROM=HarmoHelp <noreply@harmohelp.com>
