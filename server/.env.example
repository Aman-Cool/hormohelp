# PostgreSQL connection string
DATABASE_URL=postgresql://harmohelp:harmohelp@localhost:5432/harmohelp

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-minimum-32-characters

# Server
PORT=4000
NODE_ENV=development

# Frontend origin for CORS — no trailing slash
FRONTEND_ORIGIN=http://localhost:5173

# SMTP — used for email verification links and password-reset emails.
# For local development use Ethereal (https://ethereal.email) — free fake SMTP,
# no emails are actually delivered; view them at the Ethereal web interface.
# For production use a real provider: Resend, SendGrid, Mailgun, AWS SES, etc.
#
# Quick local test setup:
#   1. Visit https://ethereal.email/create
#   2. Copy the generated host / port / user / pass below
#   3. After signup, visit https://ethereal.email/messages to see the verification email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-ethereal-user@ethereal.email
SMTP_PASS=your-ethereal-password
SMTP_FROM=HarmoHelp <noreply@harmohelp.com>

# Razorpay — get test keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
